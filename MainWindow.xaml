<Window x:Class="AICodeAgentAIOGMTPC.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Title="AI Code Agent AIO-GMTPC" SizeToContent="WidthAndHeight" MinHeight="480" MinWidth="560" MaxHeight="800" MaxWidth="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="SingleBorderWindow"
        Background="#FF0F0F0F" PreviewKeyDown="Window_KeyDown" PreviewMouseWheel="Window_MouseWheel" Loaded="Window_Loaded" SourceInitialized="Window_SourceInitialized" SizeChanged="Window_SizeChanged" Width="581">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="Height" Value="27"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder" 
                                    Grid.Column="0"
                                    Width="18" 
                                    Height="18" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FF7A7A7A" 
                                    BorderThickness="1.5"
                                    CornerRadius="5"
                                    Margin="0,0,6,0">
                                <Path x:Name="checkMark"
                                      Data="M 4 8 L 8 12 L 16 4"
                                      Stroke="#FFFFFFFF"
                                      StrokeThickness="2"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              Margin="2,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#FF005FB8"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#FF005FB8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#FFCCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="Cyan"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="Cyan"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="BorderBrush" Value="#FF7A7A7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter x:Name="contentPresenter" 
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3E3E3E"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFCCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF005FB8"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF005FB8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Style tùy chỉnh cho ProgressBar với bo tròn -->
        <Style x:Key="RoundedProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Theme Toggle Switch -->
        <Style x:Key="ThemeToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <!-- Background track -->
                            <Border x:Name="track"
                                    Width="34" Height="18"
                                    CornerRadius="9"
                                    Background="#FF555555">
                                <Border x:Name="thumb"
                                        Width="14" Height="14"
                                        CornerRadius="7"
                                        Background="#FF888888"
                                        HorizontalAlignment="Left"
                                        Margin="2,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                </Border>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#FF00AA00"/>
                                <Setter TargetName="thumb" Property="Background" Value="#FF00FF00"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="track" Property="BorderBrush" Value="#FFCCCCCC"/>
                                <Setter TargetName="track" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="15" x:Name="MainGrid" Background="#FF0F0F0F">
        <Grid.Resources>
            <!-- Định nghĩa Style cho WrapPanel responsive -->
            <Style x:Key="ResponsiveWrapPanelStyle" TargetType="WrapPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Style.Triggers>
                    <!-- Khi chiều rộng nhỏ hơn chiều cao (chế độ dọc), đổi sang dọc -->
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="300">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="400">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="500">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Định nghĩa Style cho StackPanel responsive cho buttons -->
            <Style x:Key="ResponsiveButtonPanelStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Style.Triggers>
                    <!-- Khi chiều rộng nhỏ hơn chiều cao (chế độ dọc), đổi sang dọc -->
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="300">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="400">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="500">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="542*"/>
            <ColumnDefinition Width="97*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header Section -->
        <Border x:Name="HeaderBorder" Grid.Row="0" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,20" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="AI Code Agent AIO-GMTPC"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="Yellow"
                                Margin="0,0,10,5" Height="29" Width="138"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,0,0,0">
                    <Grid VerticalAlignment="Center" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Width="180" Text="Tác giả: Ma Minh Toàn 1993" FontSize="13" Foreground="LightGreen" VerticalAlignment="Center"/>
                        <Button x:Name="BtnDonate"
                                Grid.Column="1"
                                Content="Ủng hộ tác giả"
                                Background="DarkGreen"
                                BorderBrush="#FF005FB8"
                                Foreground="#FFE6E6E6"
                                FontSize="9"
                                Padding="4,2"
                                Margin="0,0,12,0"
                                HorizontalAlignment="Left"
                                Click="BtnExit_Click" Height="22" Width="90"/>
                        <TextBlock Grid.Column="2"
                                   Text="Windows Defender: không cần tắt, Antivirus khác: phải tắt."
                                   FontSize="15"
                                   Foreground="Cyan"
                                   TextWrapping="Wrap"
                                   MinWidth="0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Scale DPI:" FontSize="10" Foreground="#FFE6E6E6" Margin="0,0,2,0" VerticalAlignment="Center"/>
                            <Button x:Name="BtnDPIMinus" Content="-" Width="22" Height="18" FontSize="10" Margin="0,0,2,0" Click="BtnDPIMinus_Click" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CboDPIValue" Width="52" Height="18" FontSize="10" SelectedValuePath="Content" SelectionChanged="CboDPIValue_SelectionChanged" Margin="0,0,2,0"
                                      HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ComboBoxItem}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBoxItem Content="50%"/>
                                <ComboBoxItem Content="60%"/>
                                <ComboBoxItem Content="70%"/>
                                <ComboBoxItem Content="80%"/>
                                <ComboBoxItem Content="90%"/>
                                <ComboBoxItem Content="100%"/>
                                <ComboBoxItem Content="110%"/>
                                <ComboBoxItem Content="120%"/>
                                <ComboBoxItem Content="130%"/>
                                <ComboBoxItem Content="140%"/>
                                <ComboBoxItem Content="150%"/>
                                <ComboBoxItem Content="160%"/>
                                <ComboBoxItem Content="170%"/>
                                <ComboBoxItem Content="180%"/>
                                <ComboBoxItem Content="200%"/>
                            </ComboBox>
                            <Button x:Name="BtnDPIPlus" Content="+" Width="22" Height="18" FontSize="10" Click="BtnDPIPlus_Click" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="Dark Theme Windows" FontSize="10" Foreground="#FFE6E6E6" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ToggleButton x:Name="TglTheme"
                                              Style="{StaticResource ThemeToggleSwitchStyle}"
                                              HorizontalAlignment="Center"
                                              Click="TglTheme_Click"/>
                                <TextBlock x:Name="BuildNumberHeaderTextBlock"
                                           Text="Build: ----"
                                           FontSize="12"
                                           Foreground="#FFF0F0F0"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Checkboxes Section with ScrollViewer -->
        <Border x:Name="TabHostBorder" Grid.Row="1" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <TabControl x:Name="MainTabControl" Background="Yellow" BorderBrush="#FF7A7A7A" SelectionChanged="MainTabControl_SelectionChanged">
                <TabControl.Resources>
                    <!-- Style cho TabItem - nhỏ gọn, 1 hàng -->
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#FF2B2B2B"/>
                        <Setter Property="Foreground" Value="NavajoWhite"/>
                        <Setter Property="FontSize" Value="10.5"/>
                        <Setter Property="Padding" Value="5,2"/>
                        <Setter Property="MinHeight" Value="21"/>
                        <Setter Property="MinWidth" Value="50"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,1,1,0"
                                            CornerRadius="3,3,0,0"
                                            Margin="0,0,-1,0">
                                        <ContentPresenter x:Name="ContentSite"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          ContentSource="Header"
                                                          Margin="5,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FF1F1F1F"/>
                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FF3E3E3E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel"
                                      Grid.Row="0"
                                      Panel.ZIndex="1"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent"/>
                            <Border x:Name="ContentPanel"
                                    Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    KeyboardNavigation.TabIndex="2"
                                    KeyboardNavigation.TabNavigation="Local"
                                    KeyboardNavigation.DirectionalNavigation="Contained">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="{TemplateBinding Padding}"
                                                  ContentTemplate="{TemplateBinding SelectedContentTemplate}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                
<TabItem Header="Tool">
                    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled" Background="#FF1F1F1F">
                        <WrapPanel x:Name="ToolPanel" Orientation="Horizontal" HorizontalAlignment="Stretch" Style="{StaticResource ResponsiveWrapPanelStyle}">
                            <CheckBox x:Name="ChkInstallIDM" Content="IDM" Width="200" Height="34" Click="ChkInstallIDM_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkInstallNeatDM" Content="Neat Download Manager" Width="200" Height="34" Click="ChkInstallNeatDM_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkVcredist" Content="Vcredist 2025-2022" Width="200" Height="34" Click="ChkVcredist_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkNotepadPlusPlus" Content="Notepad++" Width="200" Height="34" Click="ChkNotepadPlusPlus_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkFastStone" Content="FastStone Capture" Width="200" Height="34" Click="ChkFastStone_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkComfortClipboardPro" Content="Comfort Clipboard Pro" Width="200" Height="34" Click="ChkComfortClipboardPro_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkPowerISO" Content="PowerISO" Width="200" Height="34" Click="ChkPowerISO_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkMemReduct" Content="MemReduct" Width="200" Height="34" Click="ChkMemReduct_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkTeraCopy" Content="TeraCopy" Width="200" Height="34" Click="ChkTeraCopy_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkVPN1111" Content="VPN 1111 (Cloudflare)" Width="200" Height="34" Click="ChkVPN1111_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkChrome" Content="Google Chrome" Width="200" Height="34" Click="ChkChrome_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkCocCoc" Content="Cốc Cốc" Width="200" Height="34" Click="ChkCocCoc_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="ChkVMWare162Lite" Content="VMWare 16.2 lite" Width="200" Height="34" Click="ChkVMWare162Lite_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                        </WrapPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Border>
        <!-- Buttons Section -->
        <Border x:Name="ButtonsBorder" Grid.Row="2" Background="Transparent" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <StackPanel Orientation="Vertical">
                <WrapPanel x:Name="CommandWrapPanel" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,0,0,10">
                    <Border BorderBrush="#FF7A7A7A" BorderThickness="1" CornerRadius="5" Width="210">
                        <StackPanel Orientation="Horizontal" Margin="3,0,0,0">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Temp folder" Foreground="#FFE6E6E6" FontSize="10" Margin="3,3,3,0" Width="69"/>
                                <ComboBox x:Name="CboTempFolder" Width="113" Height="22" FontSize="10" Margin="3,0,3,3" SelectionChanged="CboTempFolder_SelectionChanged">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ComboBoxItem}">
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                            </StackPanel>
                            <Button x:Name="BtnOpenFolder" Content="Open folder" Width="75" Height="22" Margin="0,3,3,3" Background="DarkCyan" BorderBrush="darkcyan" Click="BtnOpenFolder_Click" VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="BtnSelectAll" Content="Select All" Width="67" Height="28" Click="BtnSelectAll_Click"/>
                    <Button x:Name="BtnSelectNone" Content="Select None" Width="77" Height="28" Click="BtnSelectNone_Click"/>
                    <Button x:Name="BtnSelectNoneAllTabs" Content="Select none for all tabs" Width="128" Height="28" Background="DarkCyan" BorderBrush="darkcyan" Click="BtnSelectNoneAllTabs_Click"/>
                    <Button x:Name="BtnInstall" Content="Install" Width="50" Height="28" Background="DarkBlue" BorderBrush="#FF005FB8" Click="BtnInstall_Click" IsEnabled="False"/>
                    <Button x:Name="BtnPause" Content="Pause" Width="47" Height="28" Background="#FFD87F00" BorderBrush="#FFD87F00" Click="BtnPause_Click" IsEnabled="False"/>
                    <Button x:Name="BtnStop" Content="Stop" Width="45" Height="28" Background="#FFB80000" BorderBrush="#FFB80000" Click="BtnStop_Click" IsEnabled="False"/>
                    <Button x:Name="BtnRefreshColor" Content="Refresh Color" Width="84" Height="28" Background="DarkMagenta" BorderBrush="DarkCyan" Click="BtnRefreshColor_Click"/>
                </WrapPanel>
                <Button x:Name="BtnDownloadPage" Content="Mạng chậm thì chọn nút rồi click vào đây để đến trang download gốc" Width="362" Height="50" Background="DarkGreen" BorderBrush="black" Click="BtnDownloadPage_Click" MouseEnter="BtnDownloadPage_MouseEnter" MouseRightButtonUp="BtnDownloadPage_MouseRightButtonUp"/>
            </StackPanel>
        </Border>

        <!-- Progress Bar Section -->
        <Border x:Name="ProgressBorder" Grid.Row="3" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <StackPanel>
                <TextBlock x:Name="PartInfoTextBlock" FontSize="14" FontWeight="Bold" Foreground="Yellow" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <ProgressBar x:Name="DownloadProgressBar" x:FieldModifier="public" Height="20" Margin="0,0,0,10" Style="{StaticResource RoundedProgressBarStyle}" Background="#FF3E3E3E" Foreground="#FF005FB8"/>
                <TextBlock x:Name="SpeedTextBlock" FontSize="13" FontWeight="Bold" Foreground="Cyan" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="ProgressTextBlock" FontSize="13" Foreground="#FFCCCCCC" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBlock x:Name="SecondaryProgressTextBlock" FontSize="12" Foreground="#FF999999" HorizontalAlignment="Center" Margin="0,0,0,10" FontStyle="Italic"/>
                <!-- Connection trace canvas: shows per-connection segments and active connection count -->
                <Grid Margin="0,8,0,0">
                    <StackPanel>
                        <!-- Build number (left) | Segments (center) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock x:Name="BuildNumberTextBlock" Text="Build: ----" FontSize="12" Foreground="#FFF0F0F0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="|" FontSize="12" Foreground="#FF666666" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="Segments:" FontSize="11" Foreground="#FFF0F0F0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CboSegmentCount" Width="72" Height="20" FontSize="11" SelectedValuePath="Content" PreviewMouseWheel="CboSegmentCount_PreviewMouseWheel" SelectionChanged="CboSegmentCount_SelectionChanged">
                                <ComboBoxItem Content="1" />
                                <ComboBoxItem Content="2" />
                                <ComboBoxItem Content="4" />
                                <ComboBoxItem Content="8" />
                                <ComboBoxItem Content="16" IsSelected="True" />
                            </ComboBox>
                        </StackPanel>
                        <!-- Connection trace bar fills the full width below -->
                        <Border x:Name="ConnectionTraceBorder" CornerRadius="4" ClipToBounds="True" Background="#FF2B2B2B" Height="18">
                            <UniformGrid x:Name="ConnectionTraceGrid" Rows="1" HorizontalAlignment="Stretch"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="ConnectionCountTextBlock" FontSize="11" Foreground="#FFF0F0F0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,4,0"/>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</Window>
<!-- AI Summary: 2026-04-25 - Tuned tab spacer sizes so sparse tabs keep full checkboxes while dense tabs retain Subtitle-like fit -->

